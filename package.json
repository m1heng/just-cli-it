{
	"name": "just-cli-it",
	"private": true,
	"description": "CLI-ify everything \u2014 turn any API/service into a powerful CLI tool",
	"packageManager": "pnpm@10.11.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "pnpm -r run build",
		"dev": "pnpm -r run dev",
		"test": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@changesets/cli": "^2.27.12",
		"@types/node": "^22.0.0",
		"typescript": "^5.7.3",
		"unbuild": "^3.3.1",
		"vitest": "^3.0.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
	}
}
